# Server-side environment variables (secrets - never expose to browser)
# Get these from your Azure AI Foundry resource

# Full Azure OpenAI endpoint including deployment name
# Format: https://{resource}.openai.azure.com/openai/deployments/{deployment}
FOUNDRY_ENDPOINT=https://your-resource.openai.azure.com/openai/deployments/gpt-4o

# API key from Azure AI Foundry
FOUNDRY_API_KEY=your-api-key-here

# Optional: port override (default 8080)
# PORT=8080
