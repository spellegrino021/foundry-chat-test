# Server-side environment variables — never exposed to the browser.
# Copy this file to .env for local development.

# The base OpenAI-protocol endpoint for your published Foundry agent application.
# Format: https://{resource}.services.ai.azure.com/api/projects/{project}/applications/{agent}/protocols/openai
# Do NOT include /responses or ?api-version= — the server appends those automatically.
FOUNDRY_AGENT_ENDPOINT=https://your-resource.services.ai.azure.com/api/projects/your-project/applications/your-agent/protocols/openai

# API key for your Azure AI Foundry resource
FOUNDRY_API_KEY=your-api-key-here

# Optional: port override (default 8080)
# PORT=8080
